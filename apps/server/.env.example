# Required
AUTH_TOKEN=                  # Access token, leave empty to auto-generate on startup
DATA_DIR=./data              # SQLite database directory, default ./data
PORT=3000                    # Listen port

# Optional
CORS_ORIGIN=http://localhost:5173  # Comma-separated, set as needed for production
SERVER_PUBLIC_DIR=           # Empty=pure API; set path=serve web build (single container)
LOG_LEVEL=info               # debug|info|warn|error
MAX_ATTACHMENT_SIZE_MB=10    # Max single attachment size (MB)
